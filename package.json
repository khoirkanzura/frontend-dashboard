{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && node -e \"const fs=require('fs'); if (fs.existsSync('public/build/.vite/manifest.json')) { fs.copyFileSync('public/build/.vite/manifest.json','public/build/manifest.json'); }\"",
        "dev": "vite"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
